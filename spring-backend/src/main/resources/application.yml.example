server:
  port: 8080
  servlet:
    context-path: /

spring:
  application:
    name: job-aggregator-backend

  # Database Configuration
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:mysql://localhost:3306/job_aggregator_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true}
    username: ${SPRING_DATASOURCE_USERNAME:root}
    password: ${SPRING_DATASOURCE_PASSWORD:your_db_password_here}
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      idle-timeout: 300000
      max-lifetime: 1800000
      connection-timeout: 20000

  # JPA / Hibernate Configuration
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect

  # Mail Configuration
  mail:
    host: ${SPRING_MAIL_HOST:smtp-relay.brevo.com}
    port: ${SPRING_MAIL_PORT:587}
    username: ${SPRING_MAIL_USERNAME:your_brevo_mail_username_here}
    password: ${SPRING_MAIL_PASSWORD:your_brevo_mail_password_here}
    from: ${from:your_sender_email_here}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

# Cloudinary Integration Config
cloudinary:
  cloud-name: ${CLOUDINARY_CLOUD_NAME:your_cloudinary_cloud_name_here}
  api-key: ${CLOUDINARY_API_KEY:your_cloudinary_api_key_here}
  api-secret: ${CLOUDINARY_API_SECRET:your_cloudinary_api_secret_here}
  folder: ${CLOUDINARY_FOLDER:job-app/images}

# Security & JWT Configuration
app:
  jwt:
    secret: ${JWT_SECRET:your_base64_jwt_secret_here}
    accessTokenExpirationMs: 43200000 # 12 hours (12 * 60 * 60 * 1000)
    refreshTokenExpirationMs: 604800000 # 7 days (7 * 24 * 60 * 60 * 1000)
  origins:
    public-portal: ${PUBLIC_PORTAL_URL:http://localhost:5173}
    admin-portal: ${ADMIN_PORTAL_URL:http://localhost:5174}
